/*
 * Arch R - R36S Clone Type5 (G80CA-MB) device tree for kernel 6.6
 *
 * Board profile for R36S clone variant "Type5" (G80CA-MB board).
 * Based on rk3326-odroid-go.dtsi (proven kernel 6.6 base).
 *
 * KEY DIFFERENCES from original R36S:
 *   - PMIC: 3.0V rails (vs 3.3V), extra LDO_REG1/LDO_REG9
 *   - Panel: different reset/enable GPIOs, 30MHz pixel clock, enable-gpios
 *   - Buttons: ALL on GPIO3 (B/C/D), thumbsticks on GPIO2 (B)
 *   - Volume: ADC-based (saradc ch2) instead of GPIO
 *   - USB OTG: disabled, vcc_host on GPIO2 PA4
 *   - Audio: no external amplifier (no spk-ctl-gpios, no use-ext-amplifier)
 *   - HP detect: GPIO2 PC6 (same as original, verified from BSP DTB)
 *   - Battery: 2775mAh (vs 3200mAh), lower charge current
 *   - SD: 100MHz max, different cd-gpios
 *   - No eMMC → SD = mmcblk0 (original has eMMC → SD = mmcblk1)
 *
 * Copyright (C) 2024-2026 Arch R Project
 */

/dts-v1/;
#include "rk3326-odroid-go.dtsi"

/ {
	model = "Game Console R36S Clone Type5";
	compatible = "gameconsole,r36s-clone-type5", "gameconsole,r36s",
		     "rockchip,rk3326";

	/* Clone has no eMMC — only SD via SDMMC controller */
	aliases {
		mmc0 = &sdmmc;  /* Primary SD slot (mmcblk0) */
	};

	/*
	 * ADC mux for dual analog sticks
	 * Clone mux GPIOs: A=GPIO2_PC0, B=GPIO2_PB7, EN=GPIO2_PB4
	 * (Verified from BSP DTB: phandle 0xbd = GPIO2 = ff260000)
	 * Channel mapping (from BSP): [2,3,1,0]
	 *   mux ch0 = Right Y, ch1 = Right X, ch2 = Left X, ch3 = Left Y
	 */
	joystick_mux_controller: mux-controller {
		compatible = "gpio-mux";
		pinctrl = <&mux_en_pins>;
		#mux-control-cells = <0>;
		mux-gpios = <&gpio2 RK_PC0 GPIO_ACTIVE_LOW>,
			    <&gpio2 RK_PB7 GPIO_ACTIVE_LOW>;
	};

	joystick_mux: adc-mux {
		compatible = "io-channel-mux";
		io-channels = <&saradc 1>;
		io-channel-names = "parent";
		#io-channel-cells = <1>;
		mux-controls = <&joystick_mux_controller>;
		channels = "0", "1", "2", "3";
	};

	analog_sticks: adc-joystick {
		compatible = "adc-joystick";
		io-channels = <&joystick_mux 0>,
			      <&joystick_mux 1>,
			      <&joystick_mux 2>,
			      <&joystick_mux 3>;
		poll-interval = <60>;
		#address-cells = <1>;
		#size-cells = <0>;

		/* Clone channel mapping: ch0=RY, ch1=RX, ch2=LX, ch3=LY */
		/* All axes inverted on clone (abs-range max < min) */
		axis@0 {
			reg = <0>;
			abs-flat = <32>;
			abs-fuzz = <32>;
			abs-range = <800 180>;
			linux,code = <ABS_RY>;
		};

		axis@1 {
			reg = <1>;
			abs-flat = <32>;
			abs-fuzz = <32>;
			abs-range = <800 180>;
			linux,code = <ABS_RX>;
		};

		axis@2 {
			reg = <2>;
			abs-flat = <32>;
			abs-fuzz = <32>;
			abs-range = <800 180>;
			linux,code = <ABS_X>;
		};

		axis@3 {
			reg = <3>;
			abs-flat = <32>;
			abs-fuzz = <32>;
			abs-range = <800 180>;
			linux,code = <ABS_Y>;
		};
	};

	/*
	 * Volume buttons: ADC-based on clone (saradc channel 2)
	 * Clone uses resistor ladder, not individual GPIO pins.
	 * Measured: Vol-up ADC ~9 (~16mV), Vol-down ADC ~166 (~292mV)
	 * Thresholds: closest-match algorithm, values near measured voltages.
	 * Reference: ROCKNIX rk3326-gameconsole-eeclone.dts
	 */
	adc-keys {
		compatible = "adc-keys";
		io-channels = <&saradc 2>;
		io-channel-names = "buttons";
		autorepeat;
		poll-interval = <100>;
		keyup-threshold-microvolt = <1800000>;

		button-vol-up {
			label = "VOLUMEUP";
			linux,code = <KEY_VOLUMEUP>;
			press-threshold-microvolt = <15000>;
		};

		button-vol-down {
			label = "VOLUMEDOWN";
			linux,code = <KEY_VOLUMEDOWN>;
			press-threshold-microvolt = <300000>;
		};
	};

	/* Battery: Clone has 2775mAh (vs 3200mAh on original) */
	battery: battery {
		compatible = "simple-battery";
		charge-full-design-microamp-hours = <2775000>;
		charge-term-current-microamp = <300000>;
		constant-charge-current-max-microamp = <800000>;
		constant-charge-voltage-max-microvolt = <4200000>;
		factory-internal-resistance-micro-ohms = <180000>;
		voltage-max-design-microvolt = <4100000>;
		voltage-min-design-microvolt = <3500000>;

		ocv-capacity-celsius = <20>;
		ocv-capacity-table-0 =  <4046950 100>, <4001920 95>, <3967900 90>, <3919950 85>,
					<3888450 80>, <3861850 75>, <3831540 70>, <3799130 65>,
					<3768190 60>, <3745650 55>, <3726610 50>, <3711630 45>,
					<3696720 40>, <3685660 35>, <3674950 30>, <3663050 25>,
					<3649470 20>, <3635260 15>, <3616920 10>, <3592440 5>,
					<3300000 0>;
	};

	/* Sound card: HP detect on GPIO2 PC6 (same as original, verified from BSP DTB) */
	rk817-sound {
		/delete-property/ simple-audio-card,routing;
		simple-audio-card,widgets = "Headphone", "Headphones";
		simple-audio-card,hp-det-gpio = <&gpio2 RK_PC6 GPIO_ACTIVE_LOW>;
		simple-audio-card,codec {
			sound-dai = <&rk817_codec>;
		};
	};

};

/* Override vcc_host: clone uses GPIO2 PA4 (vs GPIO0 PB7 on original) */
&vcc_host {
	gpio = <&gpio2 RK_PA4 GPIO_ACTIVE_HIGH>;
	pinctrl-0 = <&host_drv>;
	pinctrl-names = "default";
	/delete-property/ regulator-boot-on;
	/delete-property/ vin-supply;
};

/* ============================================================
 * Remove ODROID-specific nodes not present on clone
 * ============================================================ */
/delete-node/ &gpio_led;
/delete-node/ &pwm_led;

/* Delete ALL ODROID F-buttons (clone has different GPIOs) */
/delete-node/ &btn_f1;
/delete-node/ &btn_f2;
/delete-node/ &btn_f3;
/delete-node/ &btn_f4;
/delete-node/ &btn_f5;
/delete-node/ &btn_f6;

/* ============================================================
 * Clone gamepad buttons — ALL game buttons on GPIO3
 *
 * CRITICAL: BSP DTB phandle mapping (verified from register addresses):
 *   phandle 0x68 = ff270000 = GPIO3
 *   phandle 0xbd = ff260000 = GPIO2
 *
 * Clone Type5:    DPAD on GPIO3 C4-C7, ABXY on GPIO3 C0-C3,
 *                 shoulders on GPIO3 B2-B6, extras on GPIO3 D0-D1
 *                 thumbsticks on GPIO2 B5-B6
 *
 * Keycodes use standard BTN_* (same as original) for ES compatibility.
 * ============================================================ */
&builtin_gamepad {
	pinctrl-0 = <&btn_pins>;

	/* DPAD: clone uses GPIO3 */
	button-sw1 {
		gpios = <&gpio3 RK_PC6 GPIO_ACTIVE_LOW>;
		label = "DPAD-UP";
		linux,code = <BTN_DPAD_UP>;
	};

	button-sw2 {
		gpios = <&gpio3 RK_PC7 GPIO_ACTIVE_LOW>;
		label = "DPAD-DOWN";
		linux,code = <BTN_DPAD_DOWN>;
	};

	button-sw3 {
		gpios = <&gpio3 RK_PC4 GPIO_ACTIVE_LOW>;
		label = "DPAD-LEFT";
		linux,code = <BTN_DPAD_LEFT>;
	};

	button-sw4 {
		gpios = <&gpio3 RK_PC5 GPIO_ACTIVE_LOW>;
		label = "DPAD-RIGHT";
		linux,code = <BTN_DPAD_RIGHT>;
	};

	/* ABXY: clone has them on GPIO3 C0-C3 */
	button-sw5 {
		gpios = <&gpio3 RK_PC0 GPIO_ACTIVE_LOW>;
		label = "BTN_A";
		linux,code = <BTN_EAST>;
	};

	button-sw6 {
		gpios = <&gpio3 RK_PC1 GPIO_ACTIVE_LOW>;
		label = "BTN_B";
		linux,code = <BTN_SOUTH>;
	};

	button-sw7 {
		gpios = <&gpio3 RK_PC2 GPIO_ACTIVE_LOW>;
		label = "BTN_X";
		linux,code = <BTN_NORTH>;
	};

	button-sw8 {
		gpios = <&gpio3 RK_PC3 GPIO_ACTIVE_LOW>;
		label = "BTN_Y";
		linux,code = <BTN_WEST>;
	};

	/*
	 * Shoulders: override button-sw15/sw16 from base DTSI.
	 * Must use same node names to properly override base nodes.
	 */
	button-sw15 {
		gpios = <&gpio3 RK_PB5 GPIO_ACTIVE_LOW>;
		label = "TOP-LEFT";
		linux,code = <BTN_TL>;
	};

	button-sw16 {
		gpios = <&gpio3 RK_PB3 GPIO_ACTIVE_LOW>;
		label = "TOP-RIGHT";
		linux,code = <BTN_TR>;
	};

	/* Thumbstick buttons: on GPIO2 (verified from BSP DTB) */
	button-thumbl {
		gpios = <&gpio2 RK_PB5 GPIO_ACTIVE_LOW>;
		label = "BTN_THUMBL";
		linux,code = <BTN_THUMBL>;
	};

	button-thumbr {
		gpios = <&gpio2 RK_PB6 GPIO_ACTIVE_LOW>;
		label = "BTN_THUMBR";
		linux,code = <BTN_THUMBR>;
	};

	button-mode {
		gpios = <&gpio3 RK_PB2 GPIO_ACTIVE_LOW>;
		label = "BTN_MODE";
		linux,code = <BTN_MODE>;
	};

	button-select {
		gpios = <&gpio3 RK_PD0 GPIO_ACTIVE_LOW>;
		label = "SELECT";
		linux,code = <BTN_SELECT>;
	};

	button-start {
		gpios = <&gpio3 RK_PD1 GPIO_ACTIVE_LOW>;
		label = "START";
		linux,code = <BTN_START>;
	};

	button-tl2 {
		gpios = <&gpio3 RK_PB6 GPIO_ACTIVE_LOW>;
		label = "TOP-LEFT 2";
		linux,code = <BTN_TL2>;
	};

	button-tr2 {
		gpios = <&gpio3 RK_PB4 GPIO_ACTIVE_LOW>;
		label = "TOP-RIGHT 2";
		linux,code = <BTN_TR2>;
	};
};

/* ============================================================
 * Panel: Clone Type5 NV3052C 640x480 MIPI-DSI
 * Different GPIOs, timing, and init from original R36S
 * ============================================================ */
&internal_display {
	compatible = "simple-panel-dsi";
	reset-gpios = <&gpio3 RK_PD3 GPIO_ACTIVE_LOW>;
	enable-gpios = <&gpio3 RK_PA3 GPIO_ACTIVE_HIGH>;
	power-supply = <&vcc_lcd>;
	backlight = <&backlight>;

	prepare-delay-ms = <20>;
	reset-delay-ms = <20>;
	init-delay-ms = <20>;
	enable-delay-ms = <120>;
	disable-delay-ms = <20>;
	unprepare-delay-ms = <20>;

	width-mm = <153>;
	height-mm = <85>;

	dsi,flags = <0xa03>;
	dsi,format = <0>;
	dsi,lanes = <4>;

	/* Clone Type5 panel init sequence (NV3052C) */
	panel-init-sequence = [
		15 00 02 ff 30
		15 00 02 ff 52
		15 00 02 ff 01
		15 00 02 e3 00
		15 00 02 25 10
		15 00 02 28 6f
		15 00 02 29 01
		15 00 02 2a df
		15 00 02 2c 22
		15 00 02 c3 0f
